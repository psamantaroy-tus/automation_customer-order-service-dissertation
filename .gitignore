### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-files
*.bclicense
*.flf
#Test results file
TestResults.xml


# Docker
docker-compose.override.yml

# Kubernetes secrets (never commit these)
*-secret.yaml
*.secret.yaml

# Environment files
.env
.env.*
!.env.example

# Maven wrapper jar (already partially covered)
.mvn/wrapper/maven-wrapper.jar

# Test reports (already generated, no need to track)
**/surefire-reports/

# Compiled class files (redundant with target/ but explicit)
*.class

# JAR/WAR artifacts
*.jar
*.war
*.ear

# Sensitive config overrides
**/application-prod.properties
**/application-local.properties